{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/mock/data/:file*.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/app-icon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/invite/:code", "destination": "/invite.html" },
    { "source": "/experience/:id", "destination": "/experience.html" },
    { "source": "/download", "destination": "/download.html" },
    { "source": "/help", "destination": "/help.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/mock", "destination": "/mock/index.html" },
    { "source": "/mock/stripe", "destination": "/mock/stripe.html" },
    { "source": "/mock/agent-logs", "destination": "/mock/agent-logs.html" },
    { "source": "/mock/bookings", "destination": "/mock/bookings.html" },
    { "source": "/mock/experiences", "destination": "/mock/experiences.html" },
    { "source": "/mock/captain-schedule", "destination": "/mock/captain-schedule.html" },
    { "source": "/mock/captain", "destination": "/mock/captain.html" }
  ],
  "crons": [
    {
      "path": "/api/post-daily",
      "schedule": "0 15 * * *"
    }
  ]
}
