# ── Supabase (for fetching boat listings) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Social Marketing Service ──
SOCIAL_MARKETING_URL=https://your-social-marketing-project.supabase.co
SOCIAL_MARKETING_API_KEY=your-social-marketing-api-key

# ── Stripe (for console Stripe viewer) ──
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# ── Cron Secret (protects /api/post-daily and /api/stripe/* from unauthorized calls) ──
CRON_SECRET=your-cron-secret

# ── App URL (used to generate card image URLs) ──
APP_URL=https://splytpayments.com
